{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AlgoMentor",
  "version": "0.1.0",
  "identifier": "com.algomentor.app",
  "build": {
    "frontendDist": "../gui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AlgoMentor",
        "width": 1100,
        "height": 720,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "alwaysOnTop": false,
        "decorations": true,
        "center": true,
        "visible": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
